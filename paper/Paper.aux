\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Estimated model parameters for the D-gluconate sensor circuit. Values represent the ensemble mean $\pm $ standard deviation across $N = 78$ parameter sets. The first group contains pseudo-energy parameters for promoter configurations, the second group contains binding and kinetic parameters, and the last two rows are the new resource consumption parameters introduced in this study.}}{44}{}\protected@file@percent }
\newlabel{table:model-parameters}{{2}{44}{}{}{}}
