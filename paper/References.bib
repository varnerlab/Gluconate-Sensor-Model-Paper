	Journal-Full = {Physical review. E, Statistical, nonlinear, and soft matter physics},
	Mesh = {Base Sequence; Collagen; DNA; Dependovirus; Humans; Lac Operon; Models, Molecular; Principal Component Analysis; Promoter Regions, Genetic; Thermodynamics},
